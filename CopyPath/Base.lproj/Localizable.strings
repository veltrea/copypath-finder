/* Window title */
"app.windowTitle" = "CopyPath";

/* Instruction body */
"app.instructions" = "CopyPath adds a 'Copy Path' item to the Finder right-click menu under Services.\n\nTo use it, right-click any file or folder in Finder, hover over 'Services', then click 'Copy Path'. The file's path is copied to your clipboard.\n\nYou can close this window — CopyPath stays running in the background so the Service works without launching the app each time.";

/* Optional helper button — opens the Services preferences pane so the user can assign a keyboard shortcut */
"app.openSettings" = "Open Keyboard Shortcuts Settings";

/* Menu items (%@ is replaced by the app name) */
"menu.about" = "About %@";
"menu.hide" = "Hide %@";
"menu.hideOthers" = "Hide Others";
"menu.showAll" = "Show All";
"menu.quit" = "Quit %@";
"menu.window" = "Window";
"menu.minimize" = "Minimize";
"menu.close" = "Close";
